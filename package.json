{
  "name": "mystore",
  "private": true,
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "backend:bundle": "tsc -p tsconfig.backend.json && bare-pack --target ios --target android --linked --out app/app.bundle.mjs backend/dist/backend.js",
    "watch:backend": "npm-watch backend:bundle",
    "android:fix": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "autobase": "^7.22.0",
    "bare-rpc": "^1.0.0",
    "corestore": "^7.6.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.23",
    "expo-constants": "~18.0.10",
    "expo-file-system": "~19.0.17",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "hyperbee": "^2.26.5",
    "nativewind": "^4.2.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.53.0",
    "react-native": "0.81.5",
    "react-native-bare-kit": "^0.13.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.18"
  },
  "devDependencies": {
    "@types/b4a": "^1.6.5",
    "@types/react": "~19.1.0",
    "bare-pack": "^1.4.7",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "npm-watch": "^0.13.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "watch": {
    "backend:bundle": {
      "patterns": [
        "backend"
      ],
      "extensions": "js,mjs,ts,json",
      "runOnStart": true,
      "ignore": [
        "backend/dist"
      ]
    }
  }
}
